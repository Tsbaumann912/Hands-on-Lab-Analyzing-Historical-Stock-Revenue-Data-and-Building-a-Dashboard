# ── Futures Terminal — Environment Variables Template ─────────────────────────
# Copy this file to .env and fill in your actual credentials.
# NEVER commit .env to version control.

# ── Databento (gold-standard CME/ICE tick data) ───────────────────────────────
DATABENTO_API_KEY=your_databento_api_key_here

# ── CME Group Real-Time WebSocket ─────────────────────────────────────────────
CME_API_KEY=your_cme_api_key_here

# ── Alpaca Markets (order execution) ──────────────────────────────────────────
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ── Optional: Alpha Vantage (macro / fundamental data) ────────────────────────
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# ── Optional: Polygon.io (SEC filings, earnings) ──────────────────────────────
POLYGON_API_KEY=your_polygon_key_here
